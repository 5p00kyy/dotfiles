#!/bin/bash
# Steam Deck-friendly Gamescope profile for Sunshine/Moonlight streaming.
# This runs after the stock and /etc profiles, so explicitly clear old Deck overrides.
STEAM_SESSION_FILE=/usr/share/gamescope-session-plus/sessions.d/steam
[[ -f "${STEAM_SESSION_FILE}" ]] && . "${STEAM_SESSION_FILE}"

unset INTERNAL_WIDTH
unset INTERNAL_HEIGHT
unset DRM_MODE
unset ENABLE_GAMESCOPE_HDR
unset GAMESCOPE_HDR_NITS

SCREEN_WIDTH=2560
SCREEN_HEIGHT=1600
CUSTOM_REFRESH_RATES=90
export STEAM_DISPLAY_REFRESH_LIMITS=90
export DISABLE_LSFG=1
