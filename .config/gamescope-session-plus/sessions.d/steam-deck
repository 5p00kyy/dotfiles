#!/bin/bash
# Steam Deck-friendly Gamescope profile for Sunshine/Moonlight streaming.
# Keeps default steam profile intact, only overrides resolution behavior.
STEAM_SESSION_FILE=/usr/share/gamescope-session-plus/sessions.d/steam
[[ -f "${STEAM_SESSION_FILE}" ]] && . "${STEAM_SESSION_FILE}"

# Force 16:10 output for Deck streaming.
SCREEN_WIDTH=1280
SCREEN_HEIGHT=800
INTERNAL_WIDTH=1280
INTERNAL_HEIGHT=800
DRM_MODE=fixed
