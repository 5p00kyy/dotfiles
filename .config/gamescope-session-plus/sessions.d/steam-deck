#!/bin/bash
# Steam Deck-friendly Gamescope profile for Sunshine/Moonlight streaming.
# Start from the stock Steam session and only override the output mode.
STEAM_SESSION_FILE=/usr/share/gamescope-session-plus/sessions.d/steam
[[ -f "${STEAM_SESSION_FILE}" ]] && . "${STEAM_SESSION_FILE}"

SCREEN_WIDTH=2560
SCREEN_HEIGHT=1600
CUSTOM_REFRESH_RATES=45,90
export STEAM_DISPLAY_REFRESH_LIMITS=45,90
