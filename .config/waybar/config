{
  "layer": "top",
  "position": "top",
  "height": 38,
  "margin-top": 14,
  "margin-left": 14,
  "margin-right": 14,
  "spacing": 8,
  "modules-left": ["custom/profile", "custom/displaymode", "hyprland/workspaces"],
  "modules-center": ["hyprland/window"],
  "modules-right": ["custom/network", "custom/updates", "custom/system", "custom/nowplaying", "pulseaudio", "pulseaudio#microphone", "tray", "clock", "custom/power"],
  "hyprland/workspaces": {
    "format": "[ {name} ]",
    "on-click": "activate",
    "sort-by-number": true,
    "persistent-workspaces": {"*": 5}
  },
  "hyprland/window": {
    "format": "{class} :: {title}",
    "max-length": 110,
    "separate-outputs": true,
    "rewrite": {"": "[ idle ]"}
  },
  "clock": {
    "format": "[ {:%a %d %b  %H:%M} ]",
    "format-alt": "[ {:%Y-%m-%d %H:%M:%S} ]",
    "tooltip-format": "<tt>{calendar}</tt>"
  },
  "pulseaudio": {
    "format": "[ VOL {volume}%",
    "format-muted": "[ VOL muted",
    "on-click": "pavucontrol",
    "scroll-step": 5
  },
  "pulseaudio#microphone": {
    "format": " MIC {format_source} ]",
    "format-source": "{volume}%",
    "format-source-muted": "off",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
    "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SOURCE@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 5%-"
  },
  "tray": {"icon-size": 14, "spacing": 8},
  "custom/profile": {
    "exec": "~/.config/waybar/scripts/profile.sh",
    "return-type": "json",
    "interval": 5,
    "on-click": "~/.config/hypr/scripts/ops-dashboard.sh",
    "on-click-middle": "~/.config/hypr/scripts/display-mode.sh menu",
    "on-click-right": "~/.config/hypr/scripts/accent-theme.sh toggle",
    "tooltip": true
  },
  "custom/displaymode": {
    "exec": "~/.config/hypr/scripts/display-mode.sh waybar",
    "return-type": "json",
    "interval": 4,
    "on-click": "~/.config/hypr/scripts/display-mode.sh menu",
    "on-click-right": "~/.config/hypr/scripts/display-mode.sh next",
    "tooltip": true
  },
  "custom/network": {
    "exec": "~/.config/waybar/scripts/network.sh",
    "return-type": "json",
    "interval": 3,
    "tooltip": true
  },
  "custom/updates": {
    "exec": "~/.config/waybar/scripts/updates.sh",
    "return-type": "json",
    "interval": 1800,
    "on-click": "kitty --class ops-dashboard --title OPS-DASHBOARD bash -lc '~/.config/hypr/scripts/ops-dashboard-view.sh'",
    "tooltip": true
  },
  "custom/system": {
    "exec": "~/.config/waybar/scripts/system-health.sh",
    "return-type": "json",
    "interval": 3,
    "tooltip": true,
    "on-click": "~/.config/hypr/scripts/ops-dashboard.sh"
  },
  "custom/nowplaying": {
    "exec": "~/.config/waybar/scripts/nowplaying.sh",
    "interval": 3,
    "tooltip": false,
    "on-click": "playerctl play-pause"
  },
  "custom/power": {
    "format": "[ ⏻ ]",
    "tooltip": false,
    "on-click": "~/.config/waybar/scripts/power-menu.sh"
  }
}
