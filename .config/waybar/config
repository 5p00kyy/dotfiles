{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "spacing": 0,
  "height": 28,
  "modules-left": ["custom/launcher", "hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock", "custom/update", "custom/idle-indicator"],
  "modules-right": ["tray", "network", "pulseaudio", "cpu", "memory", "custom/power"],

  "custom/launcher": {
    "format": "◆",
    "on-click": "~/.config/hypr/scripts/launcher.sh",
    "tooltip-format": "Launcher"
  },

  "hyprland/workspaces": {
    "on-click": "activate",
    "format": "{name}",
    "persistent-workspaces": {"1": [], "2": [], "3": [], "4": [], "5": []}
  },

  "hyprland/window": {
    "max-length": 70,
    "separate-outputs": true,
    "rewrite": {"": "idle"}
  },

  "clock": {
    "format": "{:%a %d %b  %H:%M}",
    "tooltip-format": "<tt>{calendar}</tt>"
  },

  "custom/update": {
    "exec": "~/.config/waybar/scripts/updates.sh",
    "return-type": "json",
    "interval": 1800,
    "tooltip": true
  },

  "custom/idle-indicator": {
    "exec": "~/.config/waybar/scripts/idle-indicator.sh",
    "return-type": "json",
    "interval": 5,
    "on-click": "pidof hyprlock || hyprlock"
  },

  "network": {
    "format-wifi": "wifi",
    "format-ethernet": "eth",
    "format-disconnected": "offline",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "Connected",
    "tooltip-format-disconnected": "Disconnected"
  },

  "pulseaudio": {
    "format": "vol {volume}%",
    "format-muted": "vol muted",
    "on-click": "pavucontrol",
    "scroll-step": 5
  },

  "cpu": {
    "interval": 5,
    "format": "cpu {usage}%"
  },

  "memory": {
    "interval": 5,
    "format": "mem {}%"
  },

  "tray": {
    "icon-size": 12,
    "spacing": 10
  },

  "custom/power": {
    "format": "⏻",
    "tooltip": false,
    "on-click": "~/.config/waybar/scripts/power-menu.sh"
  }
}
