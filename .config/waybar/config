{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "spacing": 6,
  "height": 38,
  "margin-top": 10,
  "margin-left": 12,
  "margin-right": 12,
  "modules-left": ["custom/launcher", "custom/displaymode", "hyprland/workspaces"],
  "modules-center": ["hyprland/window", "custom/nowplaying"],
  "modules-right": ["custom/network", "custom/gpu", "cpu", "memory", "pulseaudio", "tray", "clock", "custom/update", "custom/power"],

  "custom/launcher": {
    "format": "◉",
    "on-click": "~/.config/hypr/scripts/launcher.sh",
    "tooltip-format": "Launcher"
  },

  "custom/displaymode": {
    "exec": "~/.config/hypr/scripts/display-mode.sh waybar",
    "return-type": "json",
    "interval": 4,
    "on-click": "~/.config/hypr/scripts/display-mode.sh menu",
    "on-click-right": "~/.config/hypr/scripts/display-mode.sh next",
    "tooltip": true
  },

  "hyprland/workspaces": {
    "on-click": "activate",
    "format": "{name}",
    "persistent-workspaces": {"1": [], "2": [], "3": [], "4": [], "5": []}
  },

  "hyprland/window": {
    "max-length": 54,
    "separate-outputs": true,
    "rewrite": {"": "idle"}
  },

  "custom/nowplaying": {
    "exec": "~/.config/waybar/scripts/nowplaying.sh",
    "interval": 3,
    "tooltip": false,
    "on-click": "playerctl play-pause"
  },

  "clock": {
    "format": "{:%a %d %b  %H:%M}",
    "tooltip-format": "<tt>{calendar}</tt>"
  },

  "custom/update": {
    "exec": "~/.config/waybar/scripts/updates.sh",
    "return-type": "json",
    "interval": 1800,
    "tooltip": true
  },

  "custom/network": {
    "exec": "~/.config/waybar/scripts/network.sh",
    "return-type": "json",
    "interval": 3,
    "tooltip": true
  },

  "custom/gpu": {
    "exec": "~/.config/waybar/scripts/gpu.sh",
    "return-type": "json",
    "interval": 3,
    "tooltip": true
  },

  "pulseaudio": {
    "format": "vol {volume}%",
    "format-muted": "vol muted",
    "on-click": "pavucontrol",
    "scroll-step": 5
  },

  "cpu": {
    "interval": 5,
    "format": "cpu {usage}%"
  },

  "memory": {
    "interval": 5,
    "format": "mem {}%"
  },

  "tray": {
    "icon-size": 14,
    "spacing": 10
  },

  "custom/power": {
    "format": "⏻",
    "tooltip": false,
    "on-click": "~/.config/waybar/scripts/power-menu.sh"
  }
}
