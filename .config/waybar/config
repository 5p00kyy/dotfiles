{
    "layer": "top",
    "position": "top",
    "height": 28,
    "margin-top": 8,
    "margin-left": 10,
    "margin-right": 10,
    "spacing": 0,

    "modules-left": [
        "clock",
        "custom/nowplaying",
        "hyprland/window"
    ],

    "modules-center": [
        "hyprland/workspaces"
    ],

    "modules-right": [
        "tray",
        "custom/network",
        "pulseaudio",
        "custom/gpu",
        "cpu",
        "memory",
        "custom/power"
    ],

    "hyprland/workspaces": {
        "format": "[ {name} ]",
        "on-click": "activate",
        "sort-by-number": true
    },

    "hyprland/window": {
        "format": "{title}",
        "max-length": 40,
        "separate-outputs": true
    },

    "clock": {
        "format": "[  {:%H:%M} ]",
        "format-alt": "[  {:%a, %d %b %Y} ]",
        "tooltip-format": "<tt>{calendar}</tt>"
    },

    "cpu": {
        "format": "[  {usage}% ]",
        "interval": 2,
        "tooltip": true
    },

    "memory": {
        "format": "[  {percentage}% ]",
        "interval": 2,
        "tooltip-format": "{used:0.1f}GB / {total:0.1f}GB"
    },

    "pulseaudio": {
        "format": "[ {icon} {volume}% ]",
        "format-muted": "[  muted ]",
        "format-icons": {
            "headphone": "",
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol",
        "scroll-step": 5
    },

    "tray": {
        "icon-size": 14,
        "spacing": 8
    },

    "custom/power": {
        "format": "[  ]",
        "tooltip-format": "Power Menu",
        "on-click": "~/.config/waybar/scripts/power-menu.sh"
    },

    "custom/gpu": {
        "exec": "~/.config/waybar/scripts/gpu.sh",
        "interval": 5,
        "tooltip": false
    },

    "custom/network": {
        "exec": "~/.config/waybar/scripts/network.sh",
        "return-type": "json",
        "interval": 3
    },

    "custom/nowplaying": {
        "exec": "~/.config/waybar/scripts/nowplaying.sh",
        "interval": 3,
        "tooltip": false,
        "on-click": "playerctl play-pause"
    }
}
